@page "/randomanime"
@inject HttpClient Http

<PageTitle>Random Anime Girl</PageTitle>

<h3>Random Anime Girl</h3>

@if (imageUrl == null && !loadFailed)
{
    <p>Loading image...</p>
}
else if (loadFailed)
{
    <p>Unable to load an image right now. Please refresh the page.</p>
}
else
{
    <img class="img-fluid rounded" src="@imageUrl" alt="Random anime girl" />
}

@code {
    private string? imageUrl;
    private bool loadFailed;

    protected override async Task OnInitializedAsync()
    {
        await LoadImage();
    }

    private async Task LoadImage()
    {
        loadFailed = false;

        try
        {
            var result = await Http.GetFromJsonAsync<NekosLifeResponse>("https://nekos.life/api/v2/img/waifu");
            imageUrl = result?.Url;
            if (string.IsNullOrWhiteSpace(imageUrl))
            {
                imageUrl = await TryNekosBestFallback();
            }

            loadFailed = string.IsNullOrWhiteSpace(imageUrl);
        }
        catch
        {
            imageUrl = await TryNekosBestFallback();
            loadFailed = string.IsNullOrWhiteSpace(imageUrl);
        }
    }

    private async Task<string?> TryNekosBestFallback()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<NekosBestResponse>("https://nekos.best/api/v2/waifu");
            return result?.Results?.FirstOrDefault()?.Url;
        }
        catch
        {
            return null;
        }
    }

    private class NekosLifeResponse
    {
        public string? Url { get; set; }
    }

    private class NekosBestResponse
    {
        public NekosBestResult[]? Results { get; set; }
    }

    private class NekosBestResult
    {
        public string? Url { get; set; }
    }
}