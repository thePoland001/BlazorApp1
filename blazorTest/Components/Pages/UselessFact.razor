@page "/uselessfact"
@inject HttpClient Http

<PageTitle>Useless Facts</PageTitle>

<h3>Random Anime Girl</h3>

@if (imageUrl == null)
{
    <p>Loading image...</p>
}
else
{
    <img class="img-fluid rounded" src="@imageUrl" alt="Random anime girl" />
}

@code {
    private string? imageUrl;

    protected override async Task OnInitializedAsync()
    {
        await LoadImage();
    }

    private async Task LoadImage()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<ImageResponse>("https://api.waifu.pics/sfw/waifu");
            imageUrl = result?.Url;
        }
        catch
        {
            imageUrl = null;
        }
    }

    private class ImageResponse
    {
        public string? Url { get; set; }
    }
}