@page "/uselessfact"
@inject HttpClient Http

<PageTitle>Useless Facts</PageTitle>

<h3>Useless Fact of the Moment</h3>

@if (fact == null)
{
    <p>Loading...</p>
}
else
{
    <p>@fact</p>
    <button class="btn btn-primary" @onclick="GetFact">Give me another</button>
}

@code {
    private string? fact;

    protected override async Task OnInitializedAsync()
    {
        await GetFact();
    }

    private async Task GetFact()
    {
        try
        {
            var url = $"https://uselessfacts.jsph.pl/api/v2/facts/random?language=en&cacheBust={DateTime.UtcNow.Ticks}";
            var result = await Http.GetFromJsonAsync<FactResponse>(url);
            fact = result?.Text ?? "Unable to load a fact.";
        }
        catch
        {
            fact = "Unable to load a fact right now. Please try again.";
        }
    }

    private class FactResponse
    {
        public string? Text { get; set; }
    }
}