@page "/randomanime"
@inject HttpClient Http

<PageTitle>Random Anime Girl</PageTitle>

<h3>Random Anime Girl</h3>

@if (imageUrl == null && !loadFailed)
{
    <p>Loading image...</p>
}
else if (loadFailed)
{
    <p>Unable to load an image right now. Please refresh the page.</p>
}
else
{
    <img class="img-fluid rounded" src="@imageUrl" alt="Random anime girl" />
}

@code {
    private string? imageUrl;
    private bool loadFailed;

    protected override async Task OnInitializedAsync()
    {
        await LoadImage();
    }

    private async Task LoadImage()
    {
        loadFailed = false;

        try
        {
            var result = await Http.GetFromJsonAsync<NekosResponse>("https://nekos.best/api/v2/waifu");
            imageUrl = result?.Results?.FirstOrDefault()?.Url;
            loadFailed = string.IsNullOrWhiteSpace(imageUrl);
        }
        catch
        {
            loadFailed = true;
            imageUrl = null;
        }
    }

    private class NekosResponse
    {
        public NekosResult[]? Results { get; set; }
    }

    private class NekosResult
    {
        public string? Url { get; set; }
    }
}